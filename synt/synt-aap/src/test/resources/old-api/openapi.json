  "paths": {
    "/aap": {
      "post": {
        "tags": [
          "Syntetisering"
        ],
        "operationId": "service.generator.get_synthetic_aap",
        "summary": "Generer syntetiske AAP-vedtak.",
        "security": [
          {
            "jwt": [
              "secret"
            ]
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "tilDato",
            "schema": {
              "type": "boolean"
            },
            "required": false,
            "description": "Bestemmer om innsendt tilDato verdi skal brukes eller om tilDato skal bli satt basert på syntetisk verdi. Default-verdi er satt til true."
          }
        ],
        "requestBody": {
          "description": "Liste med vedtak-requests.",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Vedtak-request"
                }
              },
              "examples": {
                "vedtak-request-example": {
                  "$ref": "#/components/examples/Vedtak-request-example"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Returnerer liste med syntetiske vedtak.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AAP-vedtak"
                  }
                }
              }
            }
          }
        }
      }
    },
